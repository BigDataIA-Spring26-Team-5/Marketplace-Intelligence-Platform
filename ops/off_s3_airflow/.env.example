AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1

# Use this for MinIO, Cloudflare R2, or another S3-compatible service.
# Leave empty for AWS S3.
AWS_ENDPOINT_URL=

S3_BUCKET=your-bucket-name
S3_PREFIX=open-food-facts

# Official English OFF daily CSV export.
OFF_SOURCE_URL=https://static.openfoodfacts.org/data/en.openfoodfacts.org.products.csv.gz

# Optional request timeout in seconds.
OFF_REQUEST_TIMEOUT=120
