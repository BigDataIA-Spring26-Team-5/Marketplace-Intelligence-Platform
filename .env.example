ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# LLM model routing (optional — defaults shown)
ORCHESTRATOR_LLM=deepseek/deepseek-chat
CODEGEN_LLM=deepseek/deepseek-chat
ENRICHMENT_LLM=groq/llama-3.3-70b-versatile
CRITIC_LLM=anthropic/claude-sonnet-4-6
OBSERVABILITY_LLM=groq/llama-3.1-8b-instant

# S3 enrichment tuning (optional — defaults shown)
LLM_ENRICH_BATCH_SIZE=50
LLM_ENRICH_CONCURRENCY=5

# ChromaDB (optional — defaults shown)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# UC2 Observability endpoints — override when running pipeline off-VM
# On the VM these default to localhost and work automatically
# If running from Cloud Shell or local machine, set these to the VM IP
UC2_PUSHGATEWAY_URL=localhost:9091
UC2_KAFKA_BOOTSTRAP=localhost:9092
UC2_PG_DSN=host=localhost port=5432 dbname=uc2 user=mip password=mip_pass

# GCS HMAC credentials (S3-compatible API — same key used by Airflow DAGs)
GCS_ACCESS_KEY=GOOG1E...
GCS_SECRET_KEY=...
GCS_ENDPOINT=https://storage.googleapis.com
BRONZE_BUCKET=mip-bronze-2024
SILVER_BUCKET=mip-silver-2024

# GCS Bronze Layer (Spec 007) — uses Application Default Credentials (ADC)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=mip-platform-2024

# S3 data fetcher (fetch_s3_data.py)
S3_BUCKET=your-bucket-name
S3_KEY=path/to/file.csv.gz
S3_DOWNLOAD_DIR=data/
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=
