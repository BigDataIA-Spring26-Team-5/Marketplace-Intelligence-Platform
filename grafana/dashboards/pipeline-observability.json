{
  "uid": "etl-pipeline-observability",
  "title": "ETL Pipeline Observability",
  "description": "Live data-quality view of the food-product ETL pipeline.",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "tags": [
    "etl",
    "pipeline",
    "observability"
  ],
  "templating": {
    "list": [
      {
        "name": "source",
        "type": "query",
        "label": "Source",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": "label_values({__name__=~\"etl_dq_score_post|etl_block_dq_score\",source=~\"usda/.*|off|openfda|esci\"}, source)",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "## Food-Product ETL Pipeline\n\nRaw CSVs from **USDA**, **openFDA**, **OpenFoodFacts**, and **ESCI** are cleaned block-by-block, then enriched in a three-tier cascade (**S1 rules → S2 KNN → S3 LLM**). The **DQ score** (0–100) measures completeness and validity — watch it rise from 'Before' to 'After'."
      }
    },
    {
      "id": 1,
      "type": "bargauge",
      "title": "Final DQ Score per Source (Post-Pipeline)",
      "description": "Data-quality score after the full pipeline. Each bar is one source. Green ≥ 80 = production-ready, yellow 60–80 = usable, red < 60 = needs attention.",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "text",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "text": {
          "titleSize": 14,
          "valueSize": 20
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 60,
                "color": "yellow"
              },
              {
                "value": 80,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "label_replace(max by (source) (etl_dq_score_post{source=~\"$source\",source=~\"usda/.*|off|openfda|esci\"}), \"src\", \"$1\", \"source\", \"(.*)\") or label_replace(max by (source_name) (etl_dq_score_post{source_name=~\"$source\"}), \"src\", \"$1\", \"source_name\", \"(.*)\")",
          "legendFormat": "{{src}}",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "LLM Cost per Source (USD)",
      "description": "Cumulative spend on LLM enrichment calls (tier S3) per source. The pipeline prefers cheaper tiers (S1 rules, S2 KNN) first, so this should stay small — watch for spikes that indicate S1/S2 are failing.",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "basic",
        "showUnfilled": true,
        "valueMode": "text",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "text": {
          "titleSize": 14,
          "valueSize": 14
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "min": 0,
          "noValue": "No LLM calls yet — S1/S2 resolved every row (this is the healthy case ✔)",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 0.1,
                "color": "yellow"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "label_replace(max by (source) (etl_llm_cost_usd_total{source=~\"$source\",source=~\"usda/.*|off|openfda|esci\"} > 0), \"src\", \"$1\", \"source\", \"(.*)\") or label_replace(max by (source_name) (etl_llm_cost_usd_total{source_name=~\"$source\"} > 0), \"src\", \"$1\", \"source_name\", \"(.*)\")",
          "legendFormat": "{{src}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "DQ Score: Before vs After Pipeline",
      "description": "Post adds enrichment cols (primary_category, allergens, dietary_tags, is_organic) to the completeness denominator — if enrichment leaves them null, post < pre even though more columns were produced.",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "orientation": "vertical",
        "xField": "src",
        "xTickLabelRotation": 0,
        "showValue": "always",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        },
        "text": {
          "titleSize": 14,
          "valueSize": 16
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Before"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F2495C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "After"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#37872D"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "PRE",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "label_replace(max by (source) (etl_dq_score_pre{source=~\"usda/.*|off|openfda|esci\"}), \"src\", \"$1\", \"source\", \"(.*)\")",
          "format": "table",
          "instant": true
        },
        {
          "refId": "POST",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "label_replace(max by (source) (etl_dq_score_post{source=~\"usda/.*|off|openfda|esci\"}), \"src\", \"$1\", \"source\", \"(.*)\")",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "run_id": true,
              "source": true,
              "status": true,
              "source_name": true
            },
            "renameByName": {}
          }
        },
        {
          "id": "joinByField",
          "options": {
            "byField": "src",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {
              "Value #PRE": "Before",
              "Value #POST": "After",
              "etl_dq_score_pre": "Before",
              "etl_dq_score_post": "After"
            }
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Enrichment Tier Breakdown (totals across all runs)",
      "description": "How each row's missing fields were filled. S1 (rules) is cheap, S2 (KNN) is medium, S3 (LLM) is expensive, Unresolved means no strategy worked. A healthy pipeline resolves most rows at S1.",
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": 0,
        "showValue": "always",
        "stacking": "none",
        "groupWidth": 0.9,
        "barWidth": 0.8,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        },
        "xField": "tier",
        "text": {
          "titleSize": 14,
          "valueSize": 22
        }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "decimals": 0,
          "unit": "short",
          "noValue": "No enrichment runs yet"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "S1 rules"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "S2 KNN"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "S3 LLM"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Unresolved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "label_replace(sum(max by (run_id) (etl_enrichment_s1_resolved)), \"tier\", \"S1 rules\", \"\", \"\") or label_replace(sum(max by (run_id) (etl_enrichment_s2_resolved)), \"tier\", \"S2 KNN\", \"\", \"\") or label_replace(sum(max by (run_id) (etl_enrichment_s3_resolved)), \"tier\", \"S3 LLM\", \"\", \"\") or label_replace(sum(max by (run_id) (etl_enrichment_unresolved)), \"tier\", \"Unresolved\", \"\", \"\")",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{tier}}"
        }
      ],
      "transformations": []
    },
